---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  {% comment %} 1. SIRF PAGES (About, Contact etc.) - CSS/JS filter ke sath {% endcomment %}
  {% for page in site.pages %}
    {% unless page.url contains '.css' or page.url contains '.js' or page.url == '/404.html' or page.sitemap == false %}
    <url>
      <loc>{{ site.url }}{{ page.url | remove: "index.html" }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    </url>
    {% endunless %}
  {% endfor %}

  {% comment %} 2. ARTICLES (AI, Health, Study) {% endcomment %}
  {% for post in site.posts %}
    <url>
      <loc>{{ site.url }}{{ post.url }}</loc>
      <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    </url>
  {% endfor %}

  {% for item in site.health_beauty %}
    <url>
      <loc>{{ site.url }}{{ item.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    </url>
  {% endfor %}

  {% for item in site.study %}
    <url>
      <loc>{{ site.url }}{{ item.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    </url>
  {% endfor %}

</urlset>
