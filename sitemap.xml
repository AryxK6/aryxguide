---
layout: null
---
<?xml version="1.0" encoding="UTF-8"?>
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">

  {% comment %} 1. Normal Pages {% endcomment %}
  {% for page in site.pages %}
    {% if page.url != '/404.html' and page.sitemap != false %}
    <url>
      <loc>{{ site.url }}{{ page.url | remove: "index.html" }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    </url>
    {% endif %}
  {% endfor %}

  {% comment %} 2. Main Posts Folder {% endcomment %}
  {% for post in site.posts %}
    <url>
      <loc>{{ site.url }}{{ post.url }}</loc>
      <lastmod>{{ post.date | date_to_xmlschema }}</lastmod>
    </url>
  {% endfor %}

  {% comment %} 3. Health & Beauty Articles {% endcomment %}
  {% for item in site.health_beauty %}
    <url>
      <loc>{{ site.url }}{{ item.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    </url>
  {% endfor %}

  {% comment %} 4. Study Articles {% endcomment %}
  {% for item in site.study %}
    <url>
      <loc>{{ site.url }}{{ item.url }}</loc>
      <lastmod>{{ site.time | date_to_xmlschema }}</lastmod>
    </url>
  {% endfor %}

</urlset>
